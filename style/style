body {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      margin: 0;
      font-family: Arial, sans-serif;
      font-size: 18px;
    }

    #bulb {
      max-width: 80%;
      height: auto;
      background-color: black;
      padding: 10px;
      border-radius: 10px;
      transition: background-color 0.5s ease;
    }

    button {
      width: 120px;
      margin: 10px;
      padding: 8px;
      cursor: pointer;  
    }